apiVersion: plugin.gibson.zero-day.ai/v1
kind: Plugin
metadata:
  name: {{.Name}}
  version: {{.Version}}
  description: "{{.Name}} plugin"
  author: ""
spec:
  workload_class: plugin
  runtime: process
{{- if .Secrets}}
  secrets:
{{- range .Secrets}}
  - name: {{.Name}}
    scope: {{.Scope}}
    rotation: {{.Rotation}}
    required: true
{{- end}}
{{- end}}
  methods:
  - name: Echo
    description: "Echo returns the request message unchanged."
    request_proto: "gibson.plugins.{{.Name}}.v1.EchoRequest"
    response_proto: "gibson.plugins.{{.Name}}.v1.EchoResponse"
  health:
    startup_timeout: 30s
    liveness_interval: 10s
