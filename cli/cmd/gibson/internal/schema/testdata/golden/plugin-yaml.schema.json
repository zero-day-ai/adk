{
  "$id": "https://schemas.zero-day.ai/plugin-yaml-v1.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "plugin.yaml",
  "description": "Gibson plugin manifest at apiVersion plugin.gibson.zero-day.ai/v1. Validated by github.com/zero-day-ai/sdk/plugin/manifest at startup, by gibson component validate locally, and by the daemon at registration time.",
  "type": "object",
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "additionalProperties": false,
  "properties": {
    "apiVersion": {
      "type": "string",
      "const": "plugin.gibson.zero-day.ai/v1"
    },
    "kind": {
      "type": "string",
      "const": "Plugin"
    },
    "metadata": {
      "type": "object",
      "required": ["name", "version"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]{0,61}[a-z0-9]$"
        },
        "version": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "author": {
          "type": "string"
        }
      }
    },
    "spec": {
      "type": "object",
      "required": ["workload_class", "methods"],
      "additionalProperties": false,
      "properties": {
        "workload_class": {
          "type": "string",
          "const": "plugin"
        },
        "secrets": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "scope", "rotation"],
            "additionalProperties": false,
            "properties": {
              "name": {
                "type": "string",
                "pattern": "^(cred|provider_config):[a-z0-9_/:.-]+$",
                "description": "Broker-qualified secret name (cred:* or provider_config:*)."
              },
              "scope": {
                "type": "string",
                "enum": ["startup", "per_call"]
              },
              "rotation": {
                "type": "string",
                "enum": ["live", "restart"]
              },
              "required": {
                "type": "boolean"
              }
            }
          }
        },
        "methods": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["name", "request_proto", "response_proto"],
            "additionalProperties": false,
            "properties": {
              "name": {
                "type": "string"
              },
              "description": {
                "type": "string"
              },
              "request_proto": {
                "type": "string",
                "description": "Fully-qualified protobuf message type for the method's request."
              },
              "response_proto": {
                "type": "string",
                "description": "Fully-qualified protobuf message type for the method's response."
              }
            }
          }
        },
        "runtime": {
          "type": "string",
          "enum": ["process", "pod", "setec"],
          "default": "process"
        },
        "policy": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "setec_required": {
              "type": "boolean"
            }
          }
        },
        "health": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "startup_timeout": {
              "type": "string",
              "description": "Go duration string (e.g. 30s). Defaults to 30s."
            },
            "liveness_interval": {
              "type": "string",
              "description": "Go duration string (e.g. 10s). Defaults to 10s."
            }
          }
        },
        "egress": {
          "type": "array",
          "items": {
            "type": "object"
          },
          "description": "Declared external network targets. Informational in process/pod, enforced in setec."
        }
      }
    }
  }
}
